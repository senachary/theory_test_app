{
  "name": "theory_test_app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo/metro-runtime": "~56.0.13",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "expo": "~56.0.8",
    "expo-constants": "^56.0.16",
    "expo-font": "^56.0.5",
    "expo-linking": "^56.0.13",
    "expo-router": "^56.2.8",
    "expo-status-bar": "~56.0.4",
    "nativewind": "^4.2.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "^3.0.0",
    "react-native-reanimated": "^4.4.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-web": "^0.21.2",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^56.0.14",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "css": "tailwindcss -i ./global.css -o ./global.compiled.css",
    "css:watch": "tailwindcss -i ./global.css -o ./global.compiled.css --watch",
    "start": "npm run css && expo start",
    "android": "npm run css && expo start --android",
    "ios": "npm run css && expo start --ios",
    "web": "npm run css && expo start --web",
    "build:web": "npm run css && expo export --platform web",
    "vercel-build": "npm run css && expo export --platform web"
  },
  "private": true
}
